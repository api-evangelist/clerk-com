              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Number of results to return per page (1-500, default 10)."
              },
              {
                "name": "starting_after",
                "value": "",
                "type": "query",
                "description": "Cursor for pagination. Provide the ID of the last transfer from the\nprevious page to get the next page of results.\n"
